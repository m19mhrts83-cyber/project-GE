# Phase B: LINE 非公式クライアント試験用
# コピーして .env を作成:  cp .env.example .env
# .env は Git に含まれません（git-repos ルートの .gitignore）。
#
# まず ./setup_phase_b_mac.sh で .venv に CHRLINE を入れる（macOS）。

# setup_phase_b_mac.sh で使う Python（任意。未設定なら python3.13 → python3）
# PYTHON_BIN=

# この PoC フォルダ（絶対パス）
LINE_POC_HOME=

# セッション・認証キャッシュ（Git に含めない）
# 未設定時は line_unofficial_poc/.line_auth_local に自動（ローカル固定・OneDrive 非推奨）
# 既存データを移す場合: 旧フォルダの .tokens / .data / .chrline_*.json をそのままコピー
# LINE_UNOFFICIAL_AUTH_DIR=/絶対パス/.line_auth_local

# QR 再認証時に画像を自動で開く（Preview 等が立ち上がる）。未設定=開かない。開きたいときだけ 1
# LINE_CHRLINE_AUTO_OPEN_QR=1

# 試験で開きたいトーク名の一部（自前スクリプト・メモ用）
LINE_POC_CHAT_TITLE=キャラメル管理G

# オープンチャット取り込みルート YAML（例: line_unofficial_poc/open_chat_routes.yaml）
LINE_OPEN_CHAT_ROUTES_YAML=

# --- yoritoori 連携（line_to_yoritoori_clip 用）---
YORITOORI_BASE_PATH=
CONTACT_LIST_PATH=
LINE_CLIP_PROCESSED_PATH=
LINE_TO_YORITOORI_SCRIPT=

# --- 選んだライブラリが要求する変数（README に従い追記）---
# LINE_DEVICE_NAME=
# LINE_CERT_PATH=
