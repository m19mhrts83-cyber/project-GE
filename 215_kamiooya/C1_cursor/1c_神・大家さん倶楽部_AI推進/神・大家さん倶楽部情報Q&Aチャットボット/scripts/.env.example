# WeStudy スクレイプ認証
WESTUDY_USER=your-westudy-login-id
WESTUDY_PASS=your-westudy-login-password
# 未設定時は https://westudy.co.jp/login（会員向け）。wp-login 直でも可。
# WESTUDY_LOGIN_URL=https://westudy.co.jp/wp-login.php
# フォーラム一覧の起点（未設定時は神・大家コースのフォーラムタブ）
# WESTUDY_FORUM_URL=https://westudy.co.jp/course/kami-ooyasan-club?t=forums
# トピック詳細URLの先頭（未設定時は /forum/）
# WESTUDY_TOPIC_HREF_PREFIX=https://westudy.co.jp/forum

# Raimo アプリ認証（正本: RAIMO_*。旧 LIMO_* も後方互換で可）
RAIMO_APP_URL=https://ma-54t2keqdelz3.raimo-app.buzz/

# 公開URL（1段ログイン・推奨）: ミニアプリのログイン
RAIMO_APP_EMAIL=your-miniapp-email
RAIMO_APP_PASSWORD=your-miniapp-password

# 従来のポータル経由（2段）を使う場合のみ設定（公開URLだけなら空でよい）
# RAIMO_PORTAL_EMAIL=your-raimo-portal-email
# RAIMO_PORTAL_PASSWORD=your-raimo-portal-password
# RAIMO_ADMIN_EMAIL=your-admin-email
# RAIMO_ADMIN_PASSWORD=your-admin-password

# 任意設定
# 取込成果物の出力先（ログ / raw / full / delta）。未設定時は OneDrive 固定パスを使用。
# CHATBOT_OUTPUT_ROOT=/Users/matsunomasaharu2/Library/CloudStorage/OneDrive-個人用/215_神・大家さん倶楽部/C1_cursor/1c_神・大家さん倶楽部_AI推進/神・大家さん倶楽部情報Q&Aチャットボット
# state の保存先。未設定時は CHATBOT_OUTPUT_ROOT/state（推奨: OneDrive 側）。
# CHATBOT_STATE_ROOT=/Users/matsunomasaharu2/Library/CloudStorage/OneDrive-個人用/215_神・大家さん倶楽部/C1_cursor/1c_神・大家さん倶楽部_AI推進/神・大家さん倶楽部情報Q&Aチャットボット/state

# Supabase（kamiooya-qa-web / comments テーブル）
# 週次 run_update_and_import.sh で delta を upsert する場合に設定
SUPABASE_URL=https://mwubzgefkkjjbingrmqu.supabase.co
# 推奨: Dashboard → Settings → API → service_role（GitHub Secrets にも同名で登録）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 開発用フォールバック（RLS 有効化後は service_role 必須）
# SUPABASE_ANON_KEY=your-anon-key
# Supabase 失敗時も Raimo へ進める場合のみ 1
# SUPABASE_FAIL_OPEN=0
# RAIMO_HEADLESS=1
# RAIMO_UPLOAD_TIMEOUT_SEC=1800
# RAIMO_SLOW_MO_MS=0
# macOS のみ: 終了時に通知センターへ表示（upload_csv_to_raimo.py）。オフにする場合:
# RAIMO_NOTIFY_MACOS=0
# PYTHON=python3
# WESTUDY_SCRAPER=$HOME/git-repos/ProgramCode/alfred_python/westudy_forum_all.py
