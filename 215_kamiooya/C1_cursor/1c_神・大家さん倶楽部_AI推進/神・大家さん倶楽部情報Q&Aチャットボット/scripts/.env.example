# WeStudy スクレイプ認証
WESTUDY_USER=your-westudy-login-id
WESTUDY_PASS=your-westudy-login-password
# 未設定時は https://westudy.co.jp/login（会員向け）。wp-login 直でも可。
# WESTUDY_LOGIN_URL=https://westudy.co.jp/wp-login.php
# フォーラム一覧の起点（未設定時は神・大家コースのフォーラムタブ）
# WESTUDY_FORUM_URL=https://westudy.co.jp/course/kami-ooyasan-club?t=forums
# トピック詳細URLの先頭（未設定時は /forum/）
# WESTUDY_TOPIC_HREF_PREFIX=https://westudy.co.jp/forum

# LIMO（Raimo）アプリ認証
LIMO_APP_URL=https://ma-54t2keqdelz3.raimo-app.buzz/

# 1段目: ライモBiz等のポータル（推奨で明示）
LIMO_PORTAL_EMAIL=your-limo-biz-email
LIMO_PORTAL_PASSWORD=your-limo-biz-password
# 上記を空にする場合のみ、従来どおり LIMO_ADMIN_* を1段目に使用
# LIMO_ADMIN_EMAIL=your-admin-email
# LIMO_ADMIN_PASSWORD=your-admin-password

# 2段目: ミニアプリ（Q&Aチャットボット）のログイン
# ポータル通過後にアプリのログイン画面が出る場合は必須。1段で済むURLなら未設定でよい。
LIMO_APP_EMAIL=your-miniapp-email
LIMO_APP_PASSWORD=your-miniapp-password

# 任意設定
# 取込成果物の出力先（ログ / raw / full / delta）。未設定時は OneDrive 固定パスを使用。
# CHATBOT_OUTPUT_ROOT=/Users/matsunomasaharu/Library/CloudStorage/OneDrive-個人用/215_神・大家さん倶楽部/C1_cursor/1c_神・大家さん倶楽部_AI推進/神・大家さん倶楽部情報Q&Aチャットボット
# state の保存先。未設定時は CHATBOT_OUTPUT_ROOT/state（推奨: OneDrive 側）。
# CHATBOT_STATE_ROOT=/Users/matsunomasaharu/Library/CloudStorage/OneDrive-個人用/215_神・大家さん倶楽部/C1_cursor/1c_神・大家さん倶楽部_AI推進/神・大家さん倶楽部情報Q&Aチャットボット/state
# LIMO_HEADLESS=1
# LIMO_UPLOAD_TIMEOUT_SEC=1800
# LIMO_SLOW_MO_MS=0
# macOS のみ: 終了時に通知センターへ表示（upload_csv_to_limo.py）。オフにする場合:
# LIMO_NOTIFY_MACOS=0
# PYTHON=python3
# WESTUDY_SCRAPER=$HOME/git-repos/ProgramCode/alfred_python/westudy_forum_all.py
