# 日能研 MY NICHINOKEN の認証情報
# このファイルをコピーして .env にリネームし、下記に実際の値を入力してください。
# .env は .gitignore によりリポジトリに含まれません。

NICHINOKEN_USER=
NICHINOKEN_PASS=

# 東海労金 インターネットバンキング
TOKAIROKIN_USER=
TOKAIROKIN_PASS=
# 合言葉の回答（config_tokairokin.yaml の secret_phrase_auto で answer_env として参照）
# SECRET_1: 例「母親の誕生日は？」→ 画面の例に合わせ 1月1日 / １月１日 など（16文字以内）
TOKAIROKIN_SECRET_1=
TOKAIROKIN_SECRET_2=
TOKAIROKIN_SECRET_3=

# 東海労金：既定の振込先（省略時・--amount のみ時に fetch_after_login が銀行・支店・口座を補完）
# 住信SBIネット銀行イチゴ支店の例（金融機関コード0038・支店コード101）
TOKAIROKIN_DEFAULT_BANK_CODE=
TOKAIROKIN_DEFAULT_BANK_NAME=
TOKAIROKIN_DEFAULT_BRANCH_CODE=
TOKAIROKIN_DEFAULT_BRANCH_NAME=
TOKAIROKIN_DEFAULT_ACCOUNT=
# 参考（フォーム対応時に利用可）: 普通 / 当座
TOKAIROKIN_DEFAULT_ACCOUNT_KIND=

# 東海労金 OTP を Gmail で取得（finance/prudential_gmail_otp と同じトークン・スコープ）
# TOKAIROKIN_FETCH_OTP_FROM_GMAIL=0 でオフ
# TOKAIROKIN_GMAIL_TOKEN_PATH= （省略時は GMAIL_TOKEN_PATH → 1b_Cursorマニュアル/token_m19m.json）
# TOKAIROKIN_GMAIL_EXPECT_EMAIL=
# TOKAIROKIN_OTP_GMAIL_FROM=  送信元（カンマ区切り）。実メールの From に合わせる
# TOKAIROKIN_OTP_GMAIL_SUBJECT_TERMS= 件名キーワード（カンマ区切り OR）
# TOKAIROKIN_OTP_GMAIL_QUERY=  指定時は Gmail 検索式を全文上書き
# TOKAIROKIN_OTP_DIGITS=6
# TOKAIROKIN_PAUSE_BEFORE_GMAIL_OTP_MS=3000
# TOKAIROKIN_OTP_GMAIL_BASE_LOOKBACK_MS=120000

# Jarvis・Cursor Agent・統合ターミナル実行時: Enter 待ちで無限ブロック／誤入力を避ける（1 で有効）
# TOKAIROKIN_NON_INTERACTIVE=1
# 非対話時の代替待機（毫秒）。CLI は fetch_after_login.py tokairokin --non-interactive でも可
# TOKAIROKIN_NON_INTERACTIVE_PAUSE_MS=1800
# 非対話時の振込メニュー前ウェイト上限（秒）。長いほど B0470 無操作切断になりやすい
# TOKAIROKIN_NON_INTERACTIVE_TRANSFER_MENU_WAIT_CAP=2
#
# Jarvis / 自動実行では browser_automation で venv を使うこと（Homebrew Python は PEP 668 でグローバル pip 不可）
#   cd .../browser_automation && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
#   .venv/bin/python fetch_after_login.py tokairokin --non-interactive ...
