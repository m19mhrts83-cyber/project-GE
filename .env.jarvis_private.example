# Jarvis 用プライベート情報（住所・法人番号・個人情報の正本）
# -------------------------------------------------
# 使い方:
#   cp .env.jarvis_private.example .env.jarvis_private
#   エディタで .env.jarvis_private を開き、値を埋める
#
# .env.jarvis_private は .gitignore により Git / GitHub に含まれません。
# 旧 .env.home_address の自宅住所はここへ移す（HOME_ADDRESS）。
#
# 表記ルール（住所）:
#   - 番地・丁目など住所文字列内の数字 → 全角（例: ３４２番地２５）
#   - 郵便番号・電話・カード番号等 → 半角（Webフォームの専用欄用）

# --- 自宅（地図・経路・フォーム）---
HOME_POSTAL_CODE=
HOME_PREF=
HOME_ADDRESS=
HOME_ADDRESS_STREET=
HOME_ADDRESS_BANTI=
HOME_ADDRESS_KANA_STREET=
HOME_ADDRESS_KANA_BANTI=
# 住居（ローン申込）。居住年数は HOME_BUILT_YM（建築年月）から jarvis_car_loan_prefill.sh が自動計算
# HOME_OCCUPIED_SINCE=  # 入居年月が建築と異なるときだけ（未設定時は HOME_BUILT_YM を使用）
HOME_RESIDENCE_TYPE=自己所有
HOME_RESIDENCE_TYPE_CODE=1
HOME_STRUCTURE=一戸建て
HOME_BUILT_YM=
FAMILY_HOUSEHOLD_SIZE=
SPOUSE_HAS=
CHILDREN_COUNT=
# HOME_LAT=
# HOME_LON=

# --- 法人 ---
COMPANY_NAME=
CORPORATE_NUMBER=
COMPANY_POSTAL_CODE=
COMPANY_PREF=
COMPANY_ADDRESS=
COMPANY_ADDRESS_STREET=
COMPANY_ADDRESS_BANTI=
REPRESENTATIVE_NAME=

# --- 本人（任意・フォーム入力用）---
PERSONAL_NAME=
PERSONAL_NAME_KANA_FAMILY=
PERSONAL_NAME_KANA_GIVEN=
PERSONAL_BIRTHDATE=
PERSONAL_PHONE=
PERSONAL_EMAIL=

# --- ETC・マイレージ（フォーム入力・照会用）---
ETC_MILEAGE_ID=
ETC_CARD_NUMBER=
ETC_CARD_NUMBER_WEB=
ETC_CARD_EXPIRY=
ETC_ONBOARD_DEVICE_NUMBER=
ETC_VEHICLE_PLATE_LAST4=
ETC_MILEAGE_WEB_PASSWORD=
ETC_MILEAGE_VOICE_PASSWORD=

# --- ETC利用照会サービス（etc-meisai.jp）---
ETC_MEISAI_REGISTERED_AT=
ETC_MEISAI_STATEMENT_CHECK_RECORDED_AT=
ETC_MEISAI_STATEMENT_CHECK_AFTER_HOURS=4
ETC_MEISAI_USER_ID=
ETC_MEISAI_PASSWORD=
ETC_MEISAI_SECRET_QUESTION=
ETC_MEISAI_SECRET_ANSWER=
ETC_MEISAI_LAST_TRIP_DATE=

# --- Jarvis 月次ルーティン ---
# 1/true で ETC 月次確認を無効化（「もういらない」と言ったとき）
JARVIS_ETC_MONTHLY_DISABLE=

# --- Zaim（Web版予算反映）---
ZAIM_LOGIN_EMAIL=
ZAIM_PASSWORD=
# ZAIM_GOOGLE_EMAIL=

# --- 会社連絡先（任意）---
COMPANY_EMAIL=
COMPANY_PHONE=

# --- 法人口座1（名古屋銀行等）---
COMPANY_BANK_NAME=
COMPANY_BANK_BRANCH=
COMPANY_BANK_ACCOUNT_TYPE=普通
COMPANY_BANK_ACCOUNT=
COMPANY_BANK_ACCOUNT_NAME=
COMPANY_BANK_ACCOUNT_NAME_KANA=

# --- 法人口座2（PayPay銀行・法人等）---
COMPANY_BANK2_NAME=
COMPANY_BANK2_BRANCH=
COMPANY_BANK2_ACCOUNT_TYPE=普通
COMPANY_BANK2_ACCOUNT=
COMPANY_BANK2_ACCOUNT_NAME=
COMPANY_BANK2_ACCOUNT_NAME_KANA=
COMPANY_BANK2_WEB_LOGIN_PASSWORD=

# --- マイカーローン（審査申込・フォーム再利用）---
# EMPLOYMENT_OCCUPATION_CODE=1  # 1=給与所得者 2=個人事業者 3=経営者 9=その他
EMPLOYMENT_OCCUPATION=
EMPLOYER_NAME=
EMPLOYER_NAME_KANA=
EMPLOYER_POSTAL_CODE=
EMPLOYER_PREF=
EMPLOYER_ADDRESS_STREET=
EMPLOYER_ADDRESS_BANTI=
EMPLOYER_ADDRESS_KANA_STREET=
EMPLOYER_ADDRESS_KANA_BANTI=
EMPLOYER_PHONE=
EMPLOYER_EMAIL=
EMPLOYER_JOB_TITLE=
EMPLOYER_INDUSTRY_CODE=
EMPLOYER_WORK_TYPE_CODE=
EMPLOYER_EMPLOYEE_COUNT_CODE=
# EMPLOYMENT_START_YM=  # 入社年月 YYYY-MM（勤続年数は scripts で自動計算）
EMPLOYMENT_TYPE=
EMPLOYMENT_YEARS=
# 前年度税込年収 ANNUAL_INCOME_* は TAX_RETURN_* の PDF から scripts が自動算出（固定金額は保存しない）
# --- 確定申告（給与支払金額＝前年度税込年収の根拠）---
TAX_RETURN_ROOT=
TAX_RETURN_YEAR_DIR=
TAX_RETURN_PDF=
TAX_RETURN_USE_LATEST_YEAR_DIR=1
ANNUAL_INCOME_TAX=
OTHER_ANNUAL_INCOME=
SPOUSE_INCOME=
DEPENDENTS_COUNT=
# DEPENDENTS_COUNT=本人以外の扶養人数（配偶者+子など）。FAMILY_HOUSEHOLD_SIZE=本人含む合計
# 現マイカーローン
CURRENT_CAR_LOAN_BALANCE=
CURRENT_CAR_LOAN_LENDER=
CURRENT_CAR_LOAN_MONTHLY=
CURRENT_CAR_LOAN_MATURITY=
# 住宅ローン以外（経歴書等の参照元パス任意）
OTHER_LOAN_SOLAR_LENDER=
OTHER_LOAN_SOLAR_BALANCE=
OTHER_LOAN_SOLAR_MONTHLY=
OTHER_LOAN_NAGOYA_LENDER=
OTHER_LOAN_NAGOYA_PURPOSE=
OTHER_LOAN_NAGOYA_BALANCE=
OTHER_LOAN_NAGOYA_MONTHLY=
OTHER_LOAN_EDU_LENDER=
OTHER_LOAN_EDU_BALANCE=
OTHER_LOAN_EDU_MONTHLY=
OTHER_LOAN_RESUME_XLSX=
# 購入予定車
CAR_TARGET_MODEL=
CAR_DEALER_NAME=
CAR_DEALER_PHONE=
CAR_TARGET_PRICE=
CAR_LOAN_AMOUNT=
CAR_LOAN_DOWN_PAYMENT=0
CAR_LOAN_TERM_YEARS=
CAR_LOAN_BONUS_MANYEN_PER_PAYMENT=
CAR_LOAN_BONUS_MONTHS=
CAR_RESIDUAL_TARGET_MANYEN=
CAR_LOAN_PURPOSE=
MUFG_JACCS_LOGIN_PASSWORD=
MUFG_JACCS_KEYWORD_ANSWER=
# 申込フォーム等の秘密の質問（好きな食べ物等）の既定答え
JARVIS_DEFAULT_SECRET_ANSWER=
CAR_ESTIMATE_DISCOUNTED=
CAR_ESTIMATE_UNDISCOUNTED=
CAR_ESTIMATE_VALID_UNTIL=
# 申込先口座（あり/なし/未定）
MUFG_ACCOUNT=
RESONA_ACCOUNT=

# SBI証券（ETGateログイン）
SBI_SEC_USER=
SBI_SEC_LOGIN_PASSWORD=
SBI_SEC_TRADE_PASSWORD=

# --- 中部電力ミライズ / カテエネ（CCID = TC ID）---
# ログイン: https://katene.chuden.jp/ → 「ログイン」
# TC ID … カテエネ会員ID（画面表記）。ユーザー呼称「CCID」も同じ。
# パスワード … カテエネログインパスワード（$ 等を含む場合は '...' で囲む）
# 追記後「保存した」と一声 → Jarvis は source .env.jarvis_private で参照（チャットに再掲しない）
KATENE_TC_ID=
KATENE_PASSWORD=
# 任意: TC ID 再設定・通知用に登録メールを控える場合
# KATENE_LOGIN_EMAIL=

# === PP → Olive Infinite カード変更記録（テンプレート）===
# 状態: pending / done / skip / verify / n/a
# Olive Infinite（クレジットモード）— Web登録用
OLIVE_FLEXIBLE_PAY_CREDIT_NUMBER=
OLIVE_FLEXIBLE_PAY_CREDIT_NUMBER_WEB=
OLIVE_FLEXIBLE_PAY_CREDIT_EXPIRY=
OLIVE_FLEXIBLE_PAY_CREDIT_CVC=
OLIVE_FLEXIBLE_PAY_CREDIT_HOLDER=
OLIVE_FLEXIBLE_PAY_CREDIT_LAST4=
# Vpass / 三井住友カード会員認証（SBIクレカ積立・カード登録等）
# どちらか一方: VPASS_ID+VPASS_PASSWORD または SMBC_CARD_PIN（会員番号は OLIVE_FLEXIBLE_PAY_CREDIT_NUMBER_WEB）
VPASS_ID=
VPASS_PASSWORD=
SMBC_CARD_PIN=
# Myモビ（プレミアムカードローン返済口座変更）— USER+PASSWORD または CARD+PIN
MY_MOBI_USER_ID=
MY_MOBI_PASSWORD=
MY_MOBI_CARD_NUMBER=
# Oliveアカウント契約口座（Myモビで引落口座指定時。店番・口座番号はアプリでも確認可）
SMBC_OLIVE_BANK_BRANCH_CODE=
SMBC_OLIVE_BANK_ACCOUNT=
