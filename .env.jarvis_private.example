# Jarvis 用プライベート情報（住所・法人番号・個人情報の正本）
# -------------------------------------------------
# 使い方:
#   cp .env.jarvis_private.example .env.jarvis_private
#   エディタで .env.jarvis_private を開き、値を埋める
#
# .env.jarvis_private は .gitignore により Git / GitHub に含まれません。
# 旧 .env.home_address の自宅住所はここへ移す（HOME_ADDRESS）。
#
# 表記ルール（住所）:
#   - 番地・丁目など住所文字列内の数字 → 全角（例: ３４２番地２５）
#   - 郵便番号・電話・カード番号等 → 半角（Webフォームの専用欄用）

# --- 自宅（地図・経路・フォーム）---
HOME_POSTAL_CODE=
HOME_PREF=
HOME_ADDRESS=
HOME_ADDRESS_STREET=
HOME_ADDRESS_BANTI=
# HOME_LAT=
# HOME_LON=

# --- 法人 ---
COMPANY_NAME=
CORPORATE_NUMBER=
COMPANY_POSTAL_CODE=
COMPANY_PREF=
COMPANY_ADDRESS=
COMPANY_ADDRESS_STREET=
COMPANY_ADDRESS_BANTI=
REPRESENTATIVE_NAME=

# --- 本人（任意・フォーム入力用）---
PERSONAL_NAME=
PERSONAL_NAME_KANA_FAMILY=
PERSONAL_NAME_KANA_GIVEN=
PERSONAL_BIRTHDATE=
PERSONAL_PHONE=
PERSONAL_EMAIL=

# --- ETC・マイレージ（フォーム入力・照会用）---
ETC_MILEAGE_ID=
ETC_CARD_NUMBER=
ETC_CARD_NUMBER_WEB=
ETC_CARD_EXPIRY=
ETC_ONBOARD_DEVICE_NUMBER=
ETC_VEHICLE_PLATE_LAST4=
ETC_MILEAGE_WEB_PASSWORD=
ETC_MILEAGE_VOICE_PASSWORD=

# --- ETC利用照会サービス（etc-meisai.jp）---
ETC_MEISAI_REGISTERED_AT=
ETC_MEISAI_STATEMENT_CHECK_RECORDED_AT=
ETC_MEISAI_STATEMENT_CHECK_AFTER_HOURS=4
ETC_MEISAI_USER_ID=
ETC_MEISAI_PASSWORD=
ETC_MEISAI_SECRET_QUESTION=
ETC_MEISAI_SECRET_ANSWER=
ETC_MEISAI_LAST_TRIP_DATE=

# --- Jarvis 月次ルーティン ---
# 1/true で ETC 月次確認を無効化（「もういらない」と言ったとき）
JARVIS_ETC_MONTHLY_DISABLE=

# --- Zaim（Web版予算反映）---
ZAIM_LOGIN_EMAIL=
ZAIM_PASSWORD=
# ZAIM_GOOGLE_EMAIL=

# --- 会社連絡先（任意）---
COMPANY_EMAIL=
COMPANY_PHONE=
