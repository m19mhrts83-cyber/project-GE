# Jarvis 用プライベート情報（住所・法人番号・個人情報の正本）
# -------------------------------------------------
# 使い方:
#   cp .env.jarvis_private.example .env.jarvis_private
#   エディタで .env.jarvis_private を開き、値を埋める
#
# .env.jarvis_private は .gitignore により Git / GitHub に含まれません。
# 旧 .env.home_address の自宅住所はここへ移す（HOME_ADDRESS）。

# --- 自宅（地図・経路）---
HOME_ADDRESS=
# HOME_LAT=
# HOME_LON=

# --- 法人（株式会社リビングサポート松）---
COMPANY_NAME=
CORPORATE_NUMBER=
COMPANY_ADDRESS=
REPRESENTATIVE_NAME=

# --- 本人（任意・フォーム入力用）---
PERSONAL_NAME=
PERSONAL_BIRTHDATE=
PERSONAL_PHONE=
PERSONAL_EMAIL=

# --- 会社連絡先（任意）---
COMPANY_EMAIL=
COMPANY_PHONE=
